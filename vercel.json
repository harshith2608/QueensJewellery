{
  "rewrites": [
    {
      "source": "/product/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(whatsapp|facebookexternalhit|twitterbot|linkedinbot|slackbot|telegrambot|discordbot|googlebot|bingbot|applebot).*"
        }
      ],
      "destination": "/api/product-meta?id=:id"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
